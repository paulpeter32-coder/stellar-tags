# ---------------------------------------------------------------------------
# Stellar Payment Platform — environment variables
# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Optional pool tuning: append &connection_limit=10&pool_timeout=5
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellar_tags?schema=public"

# Port the API server listens on (defaults to 5000).
# PORT=5000

# Horizon listener network: "testnet" (default) or "public".
# HORIZON_NETWORK=testnet

# Redis connection string for rate limiter (defaults to redis://localhost:6379 if not provided)
# REDIS_URL="redis://localhost:6379"
